{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "dining-memory-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "clean": "rm -rf node_modules package-lock.json yarn.lock && echo 'cleaned node_modules and lockfiles'",
    "install:fresh": "npm run clean && npm install",
    "check:deps": "knip --include dependencies,unlisted --no-config-hints",
    "check:react-versions": "node ./scripts/check-react-versions.cjs",
    "test": "BROWSERSLIST_IGNORE_OLD_DATA=1 jest",
    "lint": "eslint App.tsx index.ts src tests --ext .ts,.tsx --cache --cache-location .eslintcache",
    "lint:fix": "eslint App.tsx index.ts src tests --ext .ts,.tsx --fix --cache --cache-location .eslintcache",
    "format": "prettier --write src/**/*.{ts,tsx}",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@bam.tech/react-native-image-resizer": "^3.0.11",
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/bottom-tabs": "^7.18.1",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.17.4",
    "expo": "~56.0.11",
    "expo-build-properties": "~56.0.18",
    "expo-camera": "~56.0.8",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-image-picker": "~56.0.17",
    "expo-location": "~56.0.17",
    "expo-media-library": "~56.0.7",
    "expo-sharing": "~56.0.17",
    "expo-splash-screen": "~56.0.9",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "llama.rn": "^0.12.4",
    "piexifjs": "^1.0.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.4.1",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "4.25.2",
    "react-native-worklets": "0.9.2"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.3",
    "@react-native/eslint-config": "^0.86.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.17",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "expo-dev-client": "~56.0.20",
    "jest": "~29.7.0",
    "jest-environment-jsdom": "~29.7.0",
    "jest-expo": "~56.0.5",
    "knip": "^6.16.1",
    "prettier": "^3.8.4",
    "react-native-web": "^0.21.2",
    "react-test-renderer": "19.2.7",
    "semver": "^7.8.4",
    "typescript": "~6.0.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@bam.tech/react-native-image-resizer"
        ]
      }
    }
  },
  "overrides": {
    "eslint-plugin-ft-flow": "3.0.11",
    "@expo/metro-config": {
      "postcss": "8.5.14"
    },
    "jest-environment-jsdom": {
      "jsdom": "23.2.0"
    }
  },
  "private": true
}
