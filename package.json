{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "dining-memory-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android:release": "bash ./scripts/build-android-release.sh",
    "build:android:release:full": "BUILD_ANDROID_ARCHITECTURES=armeabi-v7a,arm64-v8a,x86,x86_64 BUILD_ANDROID_VARIANT_LABEL=release-full bash ./scripts/build-android-release.sh",
    "build:android:debug": "BUILD_ANDROID_TASK=assembleDebug BUILD_ANDROID_OUTPUT_TYPE=debug BUILD_ANDROID_VARIANT_LABEL=debug BUILD_ANDROID_ARCHITECTURES= bash ./scripts/build-android-release.sh",
    "install:android:release": "bash ./scripts/install-android-artifact.sh",
    "install:android:debug": "INSTALL_ANDROID_VARIANT=debug bash ./scripts/install-android-artifact.sh",
    "android:gradle": "cd android && ./gradlew",
    "clean": "rm -rf node_modules package-lock.json yarn.lock && echo 'cleaned node_modules and lockfiles'",
    "install:fresh": "npm run clean && npm install",
    "check:deps": "knip --include dependencies,unlisted --no-config-hints",
    "check:react-versions": "node ./scripts/check-react-versions.cjs",
    "test": "BROWSERSLIST_IGNORE_OLD_DATA=1 jest",
    "lint": "eslint App.tsx index.ts src tests --ext .ts,.tsx --cache --cache-location .eslintcache",
    "lint:fix": "eslint App.tsx index.ts src tests --ext .ts,.tsx --fix --cache --cache-location .eslintcache",
    "format": "prettier --write src/**/*.{ts,tsx}",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@bam.tech/react-native-image-resizer": "^3.0.11",
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/bottom-tabs": "^7.18.13",
    "@react-navigation/native": "^7.3.7",
    "@react-navigation/native-stack": "^7.18.5",
    "expo": "^57",
    "expo-build-properties": "~57.0.6",
    "expo-camera": "~57.0.3",
    "expo-dev-client": "~57.0.7",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-image-picker": "~57.0.5",
    "expo-location": "~57.0.5",
    "expo-media-library": "~57.0.3",
    "expo-sharing": "~57.0.6",
    "expo-splash-screen": "~57.0.4",
    "expo-sqlite": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "llama.rn": "^0.12.6",
    "piexifjs": "^1.0.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.2",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "4.26.2",
    "react-native-worklets": "0.11.1"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.2.0",
    "@react-native/eslint-config": "^0.86.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.17",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "~29.7.0",
    "jest-environment-jsdom": "~29.7.0",
    "jest-expo": "~57.0.2",
    "knip": "^6.27.0",
    "prettier": "^3.9.5",
    "react-native-web": "^0.21.2",
    "react-test-renderer": "19.2.7",
    "semver": "^7.8.5",
    "typescript": "~6.0.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@bam.tech/react-native-image-resizer"
        ]
      }
    }
  },
  "overrides": {
    "eslint-plugin-ft-flow": "3.0.11",
    "@expo/metro-config": {
      "postcss": "8.5.14"
    },
    "jest-environment-jsdom": {
      "jsdom": "23.2.0"
    },
    "uuid": "11.1.1"
  },
  "private": true,
  "allowScripts": {
    "llama.rn@0.12.5": true,
    "fsevents@2.3.3": true
  }
}
