{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "dining-memory-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "clean": "rm -rf node_modules package-lock.json yarn.lock && echo 'cleaned node_modules and lockfiles'",
    "install:fresh": "npm run clean && npm install",
    "check:deps": "knip --include dependencies,unlisted --no-config-hints",
    "check:react-versions": "node ./scripts/check-react-versions.cjs",
    "test": "BROWSERSLIST_IGNORE_OLD_DATA=1 jest",
    "lint": "eslint App.tsx index.ts src tests --ext .ts,.tsx --cache --cache-location .eslintcache",
    "lint:fix": "eslint App.tsx index.ts src tests --ext .ts,.tsx --fix --cache --cache-location .eslintcache",
    "format": "prettier --write src/**/*.{ts,tsx}",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@bam.tech/react-native-image-resizer": "^3.0.11",
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/bottom-tabs": "^7.16.0",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.15.0",
    "expo": "~55.0.23",
    "expo-build-properties": "~55.0.13",
    "expo-camera": "~55.0.18",
    "expo-file-system": "~55.0.19",
    "expo-font": "~55.0.7",
    "expo-image-picker": "~55.0.20",
    "expo-location": "~55.1.9",
    "expo-media-library": "~55.0.16",
    "expo-sharing": "~55.0.18",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.6",
    "llama.rn": "^0.12.0",
    "piexifjs": "^1.0.6",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.3",
    "@react-native/eslint-config": "^0.85.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "expo-dev-client": "~55.0.32",
    "jest": "~29.7.0",
    "jest-environment-jsdom": "~30.4.1",
    "jest-expo": "~55.0.17",
    "knip": "^6.12.2",
    "prettier": "^3.8.3",
    "react-dom": "19.2.0",
    "react-native-web": "^0.21.2",
    "react-test-renderer": "19.2.0",
    "semver": "^7.8.0",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@bam.tech/react-native-image-resizer"
        ]
      }
    }
  },
  "overrides": {
    "eslint-plugin-ft-flow": "3.0.11",
    "@expo/metro-config": {
      "postcss": "8.5.14"
    },
    "jest-environment-jsdom": {
      "jsdom": "23.2.0"
    }
  },
  "private": true
}
