{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "dining-memory-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "clean": "rm -rf node_modules package-lock.json yarn.lock && echo 'cleaned node_modules and lockfiles'",
    "install:fresh": "npm run clean && npm install",
    "check:deps": "npx depcheck --json --specials=expo,react-native",
    "check:react-versions": "node ./scripts/check-react-versions.cjs",
    "test": "BROWSERSLIST_IGNORE_OLD_DATA=1 jest",
    "lint": "eslint App.tsx index.ts src tests --ext .ts,.tsx --cache --cache-location .eslintcache",
    "lint:fix": "eslint App.tsx index.ts src tests --ext .ts,.tsx --fix --cache --cache-location .eslintcache",
    "format": "prettier --write src/**/*.{ts,tsx}",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@nozbe/watermelondb": "^0.28.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "async-mutex": "^0.5.0",
    "date-fns": "^4.1.0",
    "expo": "~55.0.14",
    "expo-build-properties": "~55.0.13",
    "expo-camera": "~55.0.15",
    "expo-file-system": "~55.0.16",
    "expo-font": "~55.0.6",
    "expo-media-library": "~55.0.14",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-image-resizer": "^1.4.5",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.3",
    "@react-native/eslint-config": "^0.85.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "expo-dev-client": "~55.0.27",
    "jest": "~29.7.0",
    "jest-environment-jsdom": "~29.7.0",
    "jest-expo": "~55.0.15",
    "prettier": "^3.8.2",
    "react-dom": "19.2.0",
    "react-native-web": "^0.21.2",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.3"
  },
  "private": true
}
